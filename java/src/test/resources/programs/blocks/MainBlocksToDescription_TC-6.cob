IDENTIFICATION DIVISION.
PROGRAM-ID. MainBlocksToDescription_TC-6.

ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT RESULT-FILE ASSIGN TO WS-RESULT-FILE-PATH
        ORGANIZATION IS LINE SEQUENTIAL.

DATA DIVISION.
FILE SECTION.
FD RESULT-FILE.
01 RESULT-REC PIC X(80).

WORKING-STORAGE SECTION.
    COPY DD-BLOCKS.
    COPY DD-BLOCK-STATE REPLACING LEADING ==PREFIX== BY ==LK-STATE==.
    01 LK-STATE-ID              BINARY-LONG.
    01 LK-STATE-NAME-DISPLAY    PIC X(20).
    01 LK-STATE-PROPERTY-COUNT-DISPLAY PIC 9(10).
    01 OUTPUT-LINE              PIC X(80) VALUE SPACES.
    01 WS-RESULT-FILE-PATH      PIC X(100).
    01 PROPERTY-INDEX           BINARY-LONG UNSIGNED.

PROCEDURE DIVISION.
    DISPLAY "MainBlocksToDescription_TC-6 started".
    
    *> Accept result file path from environment
    ACCEPT WS-RESULT-FILE-PATH FROM ENVIRONMENT "RESULT_FILE_PATH"
    
    *> Accept inputs dynamically from environment
    ACCEPT LK-STATE-ID FROM ENVIRONMENT "LK-STATE-ID"
    
    *> Call the subprogram
    CALL 'Blocks-ToDescription' USING LK-STATE-ID LK-STATE-DESCRIPTION
    DISPLAY "Blocks-ToDescription returned"
    
    *> Write outputs to file
    OPEN OUTPUT RESULT-FILE
    
    *> Write LK-STATE-NAME
    MOVE LK-STATE-NAME TO LK-STATE-NAME-DISPLAY
    STRING "LK-STATE-NAME=" DELIMITED BY SIZE
           LK-STATE-NAME-DISPLAY DELIMITED BY SIZE
           INTO OUTPUT-LINE
    END-STRING
    MOVE OUTPUT-LINE TO RESULT-REC
    WRITE RESULT-REC
    
    *> Write LK-STATE-PROPERTY-COUNT
    MOVE LK-STATE-PROPERTY-COUNT TO LK-STATE-PROPERTY-COUNT-DISPLAY
    STRING "LK-STATE-PROPERTY-COUNT=" DELIMITED BY SIZE
           LK-STATE-PROPERTY-COUNT-DISPLAY DELIMITED BY SIZE
           INTO OUTPUT-LINE
    END-STRING
    MOVE OUTPUT-LINE TO RESULT-REC
    WRITE RESULT-REC
    
    *> Write property names and values
    PERFORM VARYING PROPERTY-INDEX FROM 1 BY 1 UNTIL PROPERTY-INDEX > LK-STATE-PROPERTY-COUNT
        STRING "LK-STATE-PROPERTY-NAME-" DELIMITED BY SIZE
               PROPERTY-INDEX DELIMITED BY SIZE
               "=" DELIMITED BY SIZE
               LK-STATE-PROPERTY-NAME(PROPERTY-INDEX) DELIMITED BY SIZE
               INTO OUTPUT-LINE
        END-STRING
        MOVE OUTPUT-LINE TO RESULT-REC
        WRITE RESULT-REC
        
        STRING "LK-STATE-PROPERTY-VALUE-" DELIMITED BY SIZE
               PROPERTY-INDEX DELIMITED BY SIZE
               "=" DELIMITED BY SIZE
               LK-STATE-PROPERTY-VALUE(PROPERTY-INDEX) DELIMITED BY SIZE
               INTO OUTPUT-LINE
        END-STRING
        MOVE OUTPUT-LINE TO RESULT-REC
        WRITE RESULT-REC
    END-PERFORM
    
    CLOSE RESULT-FILE
    GOBACK.
END PROGRAM MainBlocksToDescription_TC-6.

