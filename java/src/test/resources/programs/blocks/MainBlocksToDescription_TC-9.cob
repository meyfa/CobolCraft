*> --- Main-Blocks-ToDescription-TC-9 ---
*> Main program to test Blocks-ToDescription with last block in BLOCKS structure
IDENTIFICATION DIVISION.
PROGRAM-ID. Main-Blocks-ToDescription-TC-9.

ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT RESULT-FILE ASSIGN TO WS-RESULT-FILE-PATH
        ORGANIZATION IS LINE SEQUENTIAL.

DATA DIVISION.
FILE SECTION.
FD RESULT-FILE.
01 RESULT-REC PIC X(80).

WORKING-STORAGE SECTION.
    COPY DD-BLOCKS.
    COPY DD-BLOCK-STATE REPLACING LEADING ==PREFIX== BY ==LK-STATE==.
    01 LK-STATE-ID              BINARY-LONG.
    01 LK-STATE-ID-DISPLAY      PIC 9(10).
    01 OUTPUT-LINE              PIC X(80) VALUE SPACES.
    01 WS-RESULT-FILE-PATH      PIC X(100).
    01 PROPERTY-IDX             BINARY-LONG UNSIGNED.
    01 PROPERTY-IDX-DISPLAY     PIC 9(10).

PROCEDURE DIVISION.
    DISPLAY "Main-Blocks-ToDescription-TC-9 started".
    
    *> Accept result file path from environment
    ACCEPT WS-RESULT-FILE-PATH FROM ENVIRONMENT "RESULT_FILE_PATH"
    
    *> Accept inputs dynamically from environment
    ACCEPT LK-STATE-ID FROM ENVIRONMENT "LK-STATE-ID"
    
    *> Call the subprogram
    CALL 'Blocks-ToDescription' USING LK-STATE-ID LK-STATE-DESCRIPTION
    DISPLAY "Blocks-ToDescription returned with state name: " LK-STATE-NAME
    
    *> Write outputs to file
    OPEN OUTPUT RESULT-FILE
    
    *> Write LK-STATE-NAME
    MOVE SPACES TO OUTPUT-LINE
    STRING "LK-STATE-NAME=" DELIMITED BY SIZE
           LK-STATE-NAME DELIMITED BY SIZE
           INTO OUTPUT-LINE
    END-STRING
    MOVE OUTPUT-LINE TO RESULT-REC
    WRITE RESULT-REC
    
    *> Write LK-STATE-PROPERTY-COUNT
    MOVE LK-STATE-PROPERTY-COUNT TO PROPERTY-IDX-DISPLAY
    MOVE SPACES TO OUTPUT-LINE
    STRING "LK-STATE-PROPERTY-COUNT=" DELIMITED BY SIZE
           PROPERTY-IDX-DISPLAY DELIMITED BY SIZE
           INTO OUTPUT-LINE
    END-STRING
    MOVE OUTPUT-LINE TO RESULT-REC
    WRITE RESULT-REC
    
    *> Write properties
    PERFORM VARYING PROPERTY-IDX FROM 1 BY 1 UNTIL PROPERTY-IDX > LK-STATE-PROPERTY-COUNT
        MOVE PROPERTY-IDX TO PROPERTY-IDX-DISPLAY
        MOVE SPACES TO OUTPUT-LINE
        STRING "LK-STATE-PROPERTY-NAME-" DELIMITED BY SIZE
               PROPERTY-IDX-DISPLAY DELIMITED BY SIZE
               "=" DELIMITED BY SIZE
               LK-STATE-PROPERTY-NAME(PROPERTY-IDX) DELIMITED BY SIZE
               INTO OUTPUT-LINE
        END-STRING
        MOVE OUTPUT-LINE TO RESULT-REC
        WRITE RESULT-REC
        
        MOVE SPACES TO OUTPUT-LINE
        STRING "LK-STATE-PROPERTY-VALUE-" DELIMITED BY SIZE
               PROPERTY-IDX-DISPLAY DELIMITED BY SIZE
               "=" DELIMITED BY SIZE
               LK-STATE-PROPERTY-VALUE(PROPERTY-IDX) DELIMITED BY SIZE
               INTO OUTPUT-LINE
        END-STRING
        MOVE OUTPUT-LINE TO RESULT-REC
        WRITE RESULT-REC
    END-PERFORM
    
    CLOSE RESULT-FILE
    GOBACK.
    
END PROGRAM Main-Blocks-ToDescription-TC-9.
