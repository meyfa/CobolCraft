*> --- Main-Blocks-Count-TC-2 ---
IDENTIFICATION DIVISION.
PROGRAM-ID. Main-Blocks-Count-TC-2.

ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT RESULT-FILE ASSIGN TO WS-RESULT-FILE-PATH
        ORGANIZATION IS LINE SEQUENTIAL.

DATA DIVISION.
FILE SECTION.
FD RESULT-FILE.
01 RESULT-REC PIC X(80).

WORKING-STORAGE SECTION.
    COPY DD-BLOCKS.
    01 LK-COUNT                 BINARY-LONG UNSIGNED.
    01 LK-COUNT-DISPLAY         PIC 9(10).
    01 OUTPUT-LINE              PIC X(80) VALUE SPACES.
    01 WS-RESULT-FILE-PATH      PIC X(100).

PROCEDURE DIVISION.
    DISPLAY "Main-Blocks-Count-TC-2 started".
    
    *> Accept result file path from environment
    ACCEPT WS-RESULT-FILE-PATH FROM ENVIRONMENT "RESULT_FILE_PATH"
    
    *> Initialize BLOCKS structure to empty state
    MOVE 0 TO BLOCK-COUNT
    
    *> Call the subprogram
    CALL 'Blocks-Count' USING LK-COUNT
    DISPLAY "Blocks-Count returned LK-COUNT=" LK-COUNT
    
    *> Write outputs to file
    OPEN OUTPUT RESULT-FILE
    MOVE LK-COUNT TO LK-COUNT-DISPLAY
    STRING "LK-COUNT=" DELIMITED BY SIZE
           LK-COUNT-DISPLAY DELIMITED BY SIZE
           INTO OUTPUT-LINE
    END-STRING
    MOVE OUTPUT-LINE TO RESULT-REC
    WRITE RESULT-REC
    CLOSE RESULT-FILE
    
    GOBACK.
END PROGRAM Main-Blocks-Count-TC-2.

