IDENTIFICATION DIVISION.
PROGRAM-ID. Main-Blocks-GetStateIds-TC-4.

ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT RESULT-FILE ASSIGN TO WS-RESULT-FILE-PATH
        ORGANIZATION IS LINE SEQUENTIAL.

DATA DIVISION.
FILE SECTION.
FD RESULT-FILE.
01 RESULT-REC PIC X(80).

WORKING-STORAGE SECTION.
    COPY DD-BLOCKS.
    01 LK-BLOCK-ID              BINARY-LONG.
    01 LK-MINIMUM-ID            BINARY-LONG.
    01 LK-MAXIMUM-ID            BINARY-LONG.
    01 LK-MINIMUM-ID-DISPLAY    PIC 9(10).
    01 LK-MAXIMUM-ID-DISPLAY    PIC 9(10).
    01 OUTPUT-LINE              PIC X(80) VALUE SPACES.
    01 WS-RESULT-FILE-PATH      PIC X(100).

PROCEDURE DIVISION.
    DISPLAY "Main-Blocks-GetStateIds started".
    
    *> Accept result file path from environment
    ACCEPT WS-RESULT-FILE-PATH FROM ENVIRONMENT "RESULT_FILE_PATH"
    
    *> Accept inputs dynamically from environment
    ACCEPT LK-BLOCK-ID FROM ENVIRONMENT "LK-BLOCK-ID"
    
    *> Initialize BLOCKS structure with single state block
    MOVE 1 TO BLOCKS-COUNT
    MOVE 5 TO BLOCK-ENTRY-MINIMUM-STATE-ID(1)
    MOVE 5 TO BLOCK-ENTRY-MAXIMUM-STATE-ID(1)
    
    *> Call the subprogram
    CALL 'Blocks-GetStateIds' USING LK-BLOCK-ID LK-MINIMUM-ID LK-MAXIMUM-ID
    DISPLAY "Blocks-GetStateIds returned LK-MINIMUM-ID=" LK-MINIMUM-ID " LK-MAXIMUM-ID=" LK-MAXIMUM-ID
    
    *> Write outputs to file
    OPEN OUTPUT RESULT-FILE
    
    MOVE LK-MINIMUM-ID TO LK-MINIMUM-ID-DISPLAY
    STRING "LK-MINIMUM-ID=" DELIMITED BY SIZE
           LK-MINIMUM-ID-DISPLAY DELIMITED BY SIZE
           INTO OUTPUT-LINE
    END-STRING
    MOVE OUTPUT-LINE TO RESULT-REC
    WRITE RESULT-REC
    MOVE SPACES TO OUTPUT-LINE
    
    MOVE LK-MAXIMUM-ID TO LK-MAXIMUM-ID-DISPLAY
    STRING "LK-MAXIMUM-ID=" DELIMITED BY SIZE
           LK-MAXIMUM-ID-DISPLAY DELIMITED BY SIZE
           INTO OUTPUT-LINE
    END-STRING
    MOVE OUTPUT-LINE TO RESULT-REC
    WRITE RESULT-REC
    
    CLOSE RESULT-FILE
    
    GOBACK.
END PROGRAM Main-Blocks-GetStateIds-TC-4.

