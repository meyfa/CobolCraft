*> --- Main-Blocks-ToDescription-TC-4 ---
*> Main program to test Blocks-ToDescription with single property block
IDENTIFICATION DIVISION.
PROGRAM-ID. Main-Blocks-ToDescription-TC-4.

ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT RESULT-FILE ASSIGN TO WS-RESULT-FILE-PATH
        ORGANIZATION IS LINE SEQUENTIAL.

DATA DIVISION.
FILE SECTION.
FD RESULT-FILE.
01 RESULT-REC PIC X(80).

WORKING-STORAGE SECTION.
    COPY DD-BLOCKS.
    COPY DD-BLOCK-STATE REPLACING LEADING ==PREFIX== BY ==WS-STATE==.
    01 LK-STATE-ID              BINARY-LONG.
    01 LK-STATE-ID-DISPLAY      PIC 9(10).
    01 OUTPUT-LINE              PIC X(80) VALUE SPACES.
    01 WS-RESULT-FILE-PATH      PIC X(100).

PROCEDURE DIVISION.
    DISPLAY "Main-Blocks-ToDescription-TC-4 started".
    
    *> Accept result file path from environment
    ACCEPT WS-RESULT-FILE-PATH FROM ENVIRONMENT "RESULT_FILE_PATH"
    
    *> Accept inputs from environment
    ACCEPT LK-STATE-ID FROM ENVIRONMENT "LK-STATE-ID"
    
    *> Initialize test data - create a block with single property
    MOVE 1 TO BLOCK-COUNT
    MOVE "test-block" TO BLOCK-ENTRY-NAME(1)
    MOVE 1 TO BLOCK-ENTRY-PROPERTY-COUNT(1)
    MOVE 100 TO BLOCK-ENTRY-MINIMUM-STATE-ID(1)
    MOVE 101 TO BLOCK-ENTRY-MAXIMUM-STATE-ID(1)
    MOVE "test-property" TO BLOCK-ENTRY-PROPERTY-NAME(1, 1)
    MOVE 2 TO BLOCK-ENTRY-PROPERTY-VALUE-COUNT(1, 1)
    MOVE "value1" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 1, 1)
    MOVE "value2" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 1, 2)
    
    *> Call the subprogram
    CALL 'Blocks-ToDescription' USING LK-STATE-ID WS-STATE-DESCRIPTION
    DISPLAY "Blocks-ToDescription returned"
    
    *> Write outputs to file
    OPEN OUTPUT RESULT-FILE
    
    STRING "LK-STATE-NAME=" DELIMITED BY SIZE
           WS-STATE-NAME DELIMITED BY SPACE
           INTO OUTPUT-LINE
    END-STRING
    MOVE OUTPUT-LINE TO RESULT-REC
    WRITE RESULT-REC
    MOVE SPACES TO OUTPUT-LINE
    
    MOVE WS-STATE-PROPERTY-COUNT TO LK-STATE-ID-DISPLAY
    STRING "LK-STATE-PROPERTY-COUNT=" DELIMITED BY SIZE
           LK-STATE-ID-DISPLAY DELIMITED BY SIZE
           INTO OUTPUT-LINE
    END-STRING
    MOVE OUTPUT-LINE TO RESULT-REC
    WRITE RESULT-REC
    MOVE SPACES TO OUTPUT-LINE
    
    STRING "LK-STATE-PROPERTY-NAME-1=" DELIMITED BY SIZE
           WS-STATE-PROPERTY-NAME(1) DELIMITED BY SPACE
           INTO OUTPUT-LINE
    END-STRING
    MOVE OUTPUT-LINE TO RESULT-REC
    WRITE RESULT-REC
    MOVE SPACES TO OUTPUT-LINE
    
    STRING "LK-STATE-PROPERTY-VALUE-1=" DELIMITED BY SIZE
           WS-STATE-PROPERTY-VALUE(1) DELIMITED BY SPACE
           INTO OUTPUT-LINE
    END-STRING
    MOVE OUTPUT-LINE TO RESULT-REC
    WRITE RESULT-REC
    
    CLOSE RESULT-FILE
    
    GOBACK.
END PROGRAM Main-Blocks-ToDescription-TC-4.

