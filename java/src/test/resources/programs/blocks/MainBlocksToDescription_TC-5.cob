IDENTIFICATION DIVISION.
PROGRAM-ID. Main-Blocks-ToDescription-TC-5.

ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT RESULT-FILE ASSIGN TO WS-RESULT-FILE-PATH
        ORGANIZATION IS LINE SEQUENTIAL.

DATA DIVISION.
FILE SECTION.
FD RESULT-FILE.
01 RESULT-REC PIC X(80).

WORKING-STORAGE SECTION.
    COPY DD-BLOCKS.
    COPY DD-BLOCK-STATE REPLACING LEADING ==PREFIX== BY ==LK-STATE==.
    01 LK-STATE-ID              BINARY-LONG.
    01 LK-STATE-ID-DISPLAY      PIC 9(10).
    01 OUTPUT-LINE              PIC X(80) VALUE SPACES.
    01 WS-RESULT-FILE-PATH      PIC X(100).
    01 PROPERTY-INDEX           BINARY-LONG UNSIGNED.
    01 PROPERTY-INDEX-DISPLAY   PIC 9(10).
    
    *> Initialize test data - block with 16 properties
    01 WS-BLOCK-INDEX           BINARY-LONG UNSIGNED VALUE 1.

PROCEDURE DIVISION.
    DISPLAY "Main-Blocks-ToDescription-TC-5 started".
    
    *> Accept result file path from environment
    ACCEPT WS-RESULT-FILE-PATH FROM ENVIRONMENT "RESULT_FILE_PATH".
    
    *> Accept inputs from environment
    ACCEPT LK-STATE-ID FROM ENVIRONMENT "LK-STATE-ID".
    
    *> Initialize test block data with 16 properties
    MOVE 1 TO BLOCK-COUNT
    MOVE "TestBlock16Props" TO BLOCK-ENTRY-NAME(1)
    MOVE 16 TO BLOCK-ENTRY-PROPERTY-COUNT(1)
    MOVE 1 TO BLOCK-ENTRY-MINIMUM-STATE-ID(1)
    MOVE 65535 TO BLOCK-ENTRY-MAXIMUM-STATE-ID(1)
    
    *> Initialize 16 properties with 2 values each for simplicity
    MOVE "prop1" TO BLOCK-ENTRY-PROPERTY-NAME(1, 1)
    MOVE 2 TO BLOCK-ENTRY-PROPERTY-VALUE-COUNT(1, 1)
    MOVE "val1a" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 1, 1)
    MOVE "val1b" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 1, 2)
    
    MOVE "prop2" TO BLOCK-ENTRY-PROPERTY-NAME(1, 2)
    MOVE 2 TO BLOCK-ENTRY-PROPERTY-VALUE-COUNT(1, 2)
    MOVE "val2a" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 2, 1)
    MOVE "val2b" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 2, 2)
    
    MOVE "prop3" TO BLOCK-ENTRY-PROPERTY-NAME(1, 3)
    MOVE 2 TO BLOCK-ENTRY-PROPERTY-VALUE-COUNT(1, 3)
    MOVE "val3a" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 3, 1)
    MOVE "val3b" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 3, 2)
    
    MOVE "prop4" TO BLOCK-ENTRY-PROPERTY-NAME(1, 4)
    MOVE 2 TO BLOCK-ENTRY-PROPERTY-VALUE-COUNT(1, 4)
    MOVE "val4a" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 4, 1)
    MOVE "val4b" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 4, 2)
    
    MOVE "prop5" TO BLOCK-ENTRY-PROPERTY-NAME(1, 5)
    MOVE 2 TO BLOCK-ENTRY-PROPERTY-VALUE-COUNT(1, 5)
    MOVE "val5a" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 5, 1)
    MOVE "val5b" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 5, 2)
    
    MOVE "prop6" TO BLOCK-ENTRY-PROPERTY-NAME(1, 6)
    MOVE 2 TO BLOCK-ENTRY-PROPERTY-VALUE-COUNT(1, 6)
    MOVE "val6a" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 6, 1)
    MOVE "val6b" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 6, 2)
    
    MOVE "prop7" TO BLOCK-ENTRY-PROPERTY-NAME(1, 7)
    MOVE 2 TO BLOCK-ENTRY-PROPERTY-VALUE-COUNT(1, 7)
    MOVE "val7a" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 7, 1)
    MOVE "val7b" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 7, 2)
    
    MOVE "prop8" TO BLOCK-ENTRY-PROPERTY-NAME(1, 8)
    MOVE 2 TO BLOCK-ENTRY-PROPERTY-VALUE-COUNT(1, 8)
    MOVE "val8a" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 8, 1)
    MOVE "val8b" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 8, 2)
    
    MOVE "prop9" TO BLOCK-ENTRY-PROPERTY-NAME(1, 9)
    MOVE 2 TO BLOCK-ENTRY-PROPERTY-VALUE-COUNT(1, 9)
    MOVE "val9a" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 9, 1)
    MOVE "val9b" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 9, 2)
    
    MOVE "prop10" TO BLOCK-ENTRY-PROPERTY-NAME(1, 10)
    MOVE 2 TO BLOCK-ENTRY-PROPERTY-VALUE-COUNT(1, 10)
    MOVE "val10a" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 10, 1)
    MOVE "val10b" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 10, 2)
    
    MOVE "prop11" TO BLOCK-ENTRY-PROPERTY-NAME(1, 11)
    MOVE 2 TO BLOCK-ENTRY-PROPERTY-VALUE-COUNT(1, 11)
    MOVE "val11a" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 11, 1)
    MOVE "val11b" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 11, 2)
    
    MOVE "prop12" TO BLOCK-ENTRY-PROPERTY-NAME(1, 12)
    MOVE 2 TO BLOCK-ENTRY-PROPERTY-VALUE-COUNT(1, 12)
    MOVE "val12a" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 12, 1)
    MOVE "val12b" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 12, 2)
    
    MOVE "prop13" TO BLOCK-ENTRY-PROPERTY-NAME(1, 13)
    MOVE 2 TO BLOCK-ENTRY-PROPERTY-VALUE-COUNT(1, 13)
    MOVE "val13a" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 13, 1)
    MOVE "val13b" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 13, 2)
    
    MOVE "prop14" TO BLOCK-ENTRY-PROPERTY-NAME(1, 14)
    MOVE 2 TO BLOCK-ENTRY-PROPERTY-VALUE-COUNT(1, 14)
    MOVE "val14a" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 14, 1)
    MOVE "val14b" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 14, 2)
    
    MOVE "prop15" TO BLOCK-ENTRY-PROPERTY-NAME(1, 15)
    MOVE 2 TO BLOCK-ENTRY-PROPERTY-VALUE-COUNT(1, 15)
    MOVE "val15a" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 15, 1)
    MOVE "val15b" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 15, 2)
    
    MOVE "prop16" TO BLOCK-ENTRY-PROPERTY-NAME(1, 16)
    MOVE 2 TO BLOCK-ENTRY-PROPERTY-VALUE-COUNT(1, 16)
    MOVE "val16a" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 16, 1)
    MOVE "val16b" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 16, 2)
    
    *> Call the subprogram
    CALL 'Blocks-ToDescription' USING LK-STATE-ID LK-STATE-DESCRIPTION.
    DISPLAY "Blocks-ToDescription returned".
    
    *> Write outputs to file
    OPEN OUTPUT RESULT-FILE.
    
    STRING "LK-STATE-NAME=" DELIMITED BY SIZE
           LK-STATE-NAME DELIMITED BY SIZE
           INTO OUTPUT-LINE
    END-STRING
    MOVE OUTPUT-LINE TO RESULT-REC
    WRITE RESULT-REC
    
    MOVE LK-STATE-PROPERTY-COUNT TO PROPERTY-INDEX-DISPLAY
    MOVE SPACES TO OUTPUT-LINE
    STRING "LK-STATE-PROPERTY-COUNT=" DELIMITED BY SIZE
           PROPERTY-INDEX-DISPLAY DELIMITED BY SIZE
           INTO OUTPUT-LINE
    END-STRING
    MOVE OUTPUT-LINE TO RESULT-REC
    WRITE RESULT-REC
    
    *> Write all property names and values
    PERFORM VARYING PROPERTY-INDEX FROM 1 BY 1 UNTIL PROPERTY-INDEX > LK-STATE-PROPERTY-COUNT
        MOVE PROPERTY-INDEX TO PROPERTY-INDEX-DISPLAY
        MOVE SPACES TO OUTPUT-LINE
        STRING "LK-STATE-PROPERTY-NAME-" DELIMITED BY SIZE
               PROPERTY-INDEX-DISPLAY DELIMITED BY SIZE
               "=" DELIMITED BY SIZE
               LK-STATE-PROPERTY-NAME(PROPERTY-INDEX) DELIMITED BY SIZE
               INTO OUTPUT-LINE
        END-STRING
        MOVE OUTPUT-LINE TO RESULT-REC
        WRITE RESULT-REC
        
        MOVE SPACES TO OUTPUT-LINE
        STRING "LK-STATE-PROPERTY-VALUE-" DELIMITED BY SIZE
               PROPERTY-INDEX-DISPLAY DELIMITED BY SIZE
               "=" DELIMITED BY SIZE
               LK-STATE-PROPERTY-VALUE(PROPERTY-INDEX) DELIMITED BY SIZE
               INTO OUTPUT-LINE
        END-STRING
        MOVE OUTPUT-LINE TO RESULT-REC
        WRITE RESULT-REC
    END-PERFORM
    
    CLOSE RESULT-FILE.
    GOBACK.

END PROGRAM Main-Blocks-ToDescription-TC-5.

