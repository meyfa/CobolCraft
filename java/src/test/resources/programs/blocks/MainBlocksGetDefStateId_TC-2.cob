IDENTIFICATION DIVISION.
PROGRAM-ID. Main-Blocks-GetDefStateId-TC-2.

ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT RESULT-FILE ASSIGN TO WS-RESULT-FILE-PATH
        ORGANIZATION IS LINE SEQUENTIAL.

DATA DIVISION.
FILE SECTION.
FD RESULT-FILE.
01 RESULT-REC PIC X(80).

WORKING-STORAGE SECTION.
    COPY DD-BLOCKS.
    01 LK-BLOCK-ID              BINARY-LONG.
    01 LK-STATE-ID              BINARY-LONG.
    01 LK-STATE-ID-DISPLAY      PIC 9(10).
    01 OUTPUT-LINE              PIC X(80) VALUE SPACES.
    01 WS-RESULT-FILE-PATH      PIC X(100).

PROCEDURE DIVISION.
    DISPLAY "Main-Blocks-GetDefStateId-TC-2 started".
    
    *> Accept result file path from environment
    ACCEPT WS-RESULT-FILE-PATH FROM ENVIRONMENT "RESULT_FILE_PATH"
    
    *> Accept inputs dynamically from environment
    ACCEPT LK-BLOCK-ID FROM ENVIRONMENT "LK-BLOCK-ID"
    
    *> Initialize BLOCKS structure with multiple block entries
    MOVE 5 TO BLOCK-COUNT
    MOVE 100 TO BLOCK-ENTRY-DEFAULT-STATE-ID(1)
    MOVE 200 TO BLOCK-ENTRY-DEFAULT-STATE-ID(2)
    MOVE 300 TO BLOCK-ENTRY-DEFAULT-STATE-ID(3)
    MOVE 400 TO BLOCK-ENTRY-DEFAULT-STATE-ID(4)
    MOVE 500 TO BLOCK-ENTRY-DEFAULT-STATE-ID(5)
    
    *> Call the subprogram
    CALL 'Blocks-GetDefaultStateId' USING LK-BLOCK-ID LK-STATE-ID
    DISPLAY "Blocks-GetDefaultStateId returned LK-STATE-ID=" LK-STATE-ID
    
    *> Write outputs to file
    OPEN OUTPUT RESULT-FILE
    MOVE LK-STATE-ID TO LK-STATE-ID-DISPLAY
    STRING "LK-STATE-ID=" DELIMITED BY SIZE
           LK-STATE-ID-DISPLAY DELIMITED BY SIZE
           INTO OUTPUT-LINE
    END-STRING
    MOVE OUTPUT-LINE TO RESULT-REC
    WRITE RESULT-REC
    CLOSE RESULT-FILE
    
    GOBACK.
END PROGRAM Main-Blocks-GetDefStateId-TC-2.

