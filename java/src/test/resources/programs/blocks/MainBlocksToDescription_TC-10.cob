IDENTIFICATION DIVISION.
PROGRAM-ID. Main-Blocks-ToDescription-TC-10.

ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT RESULT-FILE ASSIGN TO WS-RESULT-FILE-PATH
        ORGANIZATION IS LINE SEQUENTIAL.

DATA DIVISION.
FILE SECTION.
FD RESULT-FILE.
01 RESULT-REC PIC X(80).

WORKING-STORAGE SECTION.
    COPY DD-BLOCKS.
    COPY DD-BLOCK-STATE REPLACING LEADING ==PREFIX== BY ==WS-STATE==.
    01 LK-STATE-ID              BINARY-LONG.
    01 LK-STATE-ID-DISPLAY      PIC 9(10).
    01 OUTPUT-LINE              PIC X(80) VALUE SPACES.
    01 WS-RESULT-FILE-PATH      PIC X(100).
    01 PROPERTY-INDEX           BINARY-LONG UNSIGNED.
    01 PROPERTY-INDEX-DISPLAY   PIC 9(10).
    01 BLOCK-INDEX              BINARY-LONG UNSIGNED.
    01 VALUE-INDEX              BINARY-LONG UNSIGNED.
    01 VALUE-INDEX-DISPLAY      PIC 9(10).

PROCEDURE DIVISION.
    DISPLAY "Main-Blocks-ToDescription-TC-10 started".
    
    *> Accept result file path from environment
    ACCEPT WS-RESULT-FILE-PATH FROM ENVIRONMENT "RESULT_FILE_PATH"
    
    *> Accept inputs dynamically from environment
    ACCEPT LK-STATE-ID FROM ENVIRONMENT "LK-STATE-ID"
    
    *> Initialize test data - create a block with properties having 32 values each
    MOVE 1 TO BLOCK-COUNT
    MOVE "TestBlock" TO BLOCK-ENTRY-NAME(1)
    MOVE 2 TO BLOCK-ENTRY-PROPERTY-COUNT(1)
    MOVE 1 TO BLOCK-ENTRY-MINIMUM-STATE-ID(1)
    COMPUTE BLOCK-ENTRY-MAXIMUM-STATE-ID(1) = 32 * 32 - 1
    
    *> Set up first property with 32 values
    MOVE "Property1" TO BLOCK-ENTRY-PROPERTY-NAME(1, 1)
    MOVE 32 TO BLOCK-ENTRY-PROPERTY-VALUE-COUNT(1, 1)
    PERFORM VARYING VALUE-INDEX FROM 1 BY 1 UNTIL VALUE-INDEX > 32
        MOVE VALUE-INDEX TO VALUE-INDEX-DISPLAY
        STRING "Value1_" DELIMITED BY SIZE
               VALUE-INDEX-DISPLAY DELIMITED BY SIZE
               INTO BLOCK-ENTRY-PROPERTY-VALUE(1, 1, VALUE-INDEX)
        END-STRING
    END-PERFORM
    
    *> Set up second property with 32 values
    MOVE "Property2" TO BLOCK-ENTRY-PROPERTY-NAME(1, 2)
    MOVE 32 TO BLOCK-ENTRY-PROPERTY-VALUE-COUNT(1, 2)
    PERFORM VARYING VALUE-INDEX FROM 1 BY 1 UNTIL VALUE-INDEX > 32
        MOVE VALUE-INDEX TO VALUE-INDEX-DISPLAY
        STRING "Value2_" DELIMITED BY SIZE
               VALUE-INDEX-DISPLAY DELIMITED BY SIZE
               INTO BLOCK-ENTRY-PROPERTY-VALUE(1, 2, VALUE-INDEX)
        END-STRING
    END-PERFORM
    
    *> Set LK-STATE-ID to maximum state ID
    MOVE BLOCK-ENTRY-MAXIMUM-STATE-ID(1) TO LK-STATE-ID
    
    *> Call the subprogram
    CALL 'Blocks-ToDescription' USING LK-STATE-ID WS-STATE-DESCRIPTION
    DISPLAY "Blocks-ToDescription returned with state name: " WS-STATE-NAME
    
    *> Write outputs to file
    OPEN OUTPUT RESULT-FILE
    
    STRING "LK-STATE-NAME=" DELIMITED BY SIZE
           WS-STATE-NAME DELIMITED BY SIZE
           INTO OUTPUT-LINE
    END-STRING
    MOVE OUTPUT-LINE TO RESULT-REC
    WRITE RESULT-REC
    
    MOVE WS-STATE-PROPERTY-COUNT TO PROPERTY-INDEX-DISPLAY
    STRING "LK-STATE-PROPERTY-COUNT=" DELIMITED BY SIZE
           PROPERTY-INDEX-DISPLAY DELIMITED BY SIZE
           INTO OUTPUT-LINE
    END-STRING
    MOVE OUTPUT-LINE TO RESULT-REC
    WRITE RESULT-REC
    
    *> Write property names and values
    PERFORM VARYING PROPERTY-INDEX FROM 1 BY 1 UNTIL PROPERTY-INDEX > WS-STATE-PROPERTY-COUNT
        MOVE PROPERTY-INDEX TO PROPERTY-INDEX-DISPLAY
        STRING "LK-STATE-PROPERTY-INDEX-" DELIMITED BY SIZE
               PROPERTY-INDEX-DISPLAY DELIMITED BY SIZE
               "=" DELIMITED BY SIZE
               PROPERTY-INDEX-DISPLAY DELIMITED BY SIZE
               INTO OUTPUT-LINE
        END-STRING
        MOVE OUTPUT-LINE TO RESULT-REC
        WRITE RESULT-REC

        STRING "LK-STATE-PROPERTY-NAME-" DELIMITED BY SIZE
               PROPERTY-INDEX-DISPLAY DELIMITED BY SIZE
               "=" DELIMITED BY SIZE
               WS-STATE-PROPERTY-NAME(PROPERTY-INDEX) DELIMITED BY SIZE
               INTO OUTPUT-LINE
        END-STRING
        MOVE OUTPUT-LINE TO RESULT-REC
        WRITE RESULT-REC
        
        STRING "LK-STATE-PROPERTY-VALUE-" DELIMITED BY SIZE
               PROPERTY-INDEX-DISPLAY DELIMITED BY SIZE
               "=" DELIMITED BY SIZE
               WS-STATE-PROPERTY-VALUE(PROPERTY-INDEX) DELIMITED BY SIZE
               INTO OUTPUT-LINE
        END-STRING
        MOVE OUTPUT-LINE TO RESULT-REC
        WRITE RESULT-REC
    END-PERFORM
    
    CLOSE RESULT-FILE
    GOBACK.
    
END PROGRAM Main-Blocks-ToDescription-TC-10.
