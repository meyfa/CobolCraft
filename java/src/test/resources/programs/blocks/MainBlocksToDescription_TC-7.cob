*> --- Main-Blocks-ToDescription-TC-7 ---
*> Main program to test Blocks-ToDescription with last state ID of a block
IDENTIFICATION DIVISION.
PROGRAM-ID. Main-Blocks-ToDescription-TC-7.

ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT RESULT-FILE ASSIGN TO WS-RESULT-FILE-PATH
        ORGANIZATION IS LINE SEQUENTIAL.

DATA DIVISION.
FILE SECTION.
FD RESULT-FILE.
01 RESULT-REC PIC X(80).

WORKING-STORAGE SECTION.
    COPY DD-BLOCKS.
    COPY DD-BLOCK-STATE REPLACING LEADING ==PREFIX== BY ==WS-STATE==.
    01 LK-STATE-ID              BINARY-LONG.
    01 LK-STATE-ID-DISPLAY      PIC 9(10).
    01 OUTPUT-LINE              PIC X(80) VALUE SPACES.
    01 WS-RESULT-FILE-PATH      PIC X(100).

PROCEDURE DIVISION.
    DISPLAY "Main-Blocks-ToDescription-TC-7 started".
    
    *> Accept result file path from environment
    ACCEPT WS-RESULT-FILE-PATH FROM ENVIRONMENT "RESULT_FILE_PATH"
    
    *> Accept inputs from environment
    ACCEPT LK-STATE-ID FROM ENVIRONMENT "LK-STATE-ID"
    
    *> Initialize blocks data structure
    PERFORM INITIALIZE-BLOCKS
    
    *> Call the subprogram
    CALL 'Blocks-ToDescription' USING LK-STATE-ID WS-STATE-DESCRIPTION
    DISPLAY "Blocks-ToDescription returned with state name: " WS-STATE-NAME
    
    *> Write outputs to file
    OPEN OUTPUT RESULT-FILE
    
    *> Write LK-STATE-NAME
    MOVE SPACES TO OUTPUT-LINE
    STRING "LK-STATE-NAME=" DELIMITED BY SIZE
           WS-STATE-NAME DELIMITED BY SIZE
           INTO OUTPUT-LINE
    END-STRING
    MOVE OUTPUT-LINE TO RESULT-REC
    WRITE RESULT-REC
    
    *> Write LK-STATE-PROPERTY-COUNT
    MOVE WS-STATE-PROPERTY-COUNT TO LK-STATE-ID-DISPLAY
    MOVE SPACES TO OUTPUT-LINE
    STRING "LK-STATE-PROPERTY-COUNT=" DELIMITED BY SIZE
           LK-STATE-ID-DISPLAY DELIMITED BY SIZE
           INTO OUTPUT-LINE
    END-STRING
    MOVE OUTPUT-LINE TO RESULT-REC
    WRITE RESULT-REC
    
    *> Write property names and values
    PERFORM VARYING LK-STATE-ID FROM 1 BY 1 UNTIL LK-STATE-ID > WS-STATE-PROPERTY-COUNT
        MOVE LK-STATE-ID TO LK-STATE-ID-DISPLAY
        MOVE SPACES TO OUTPUT-LINE
        STRING "LK-STATE-PROPERTY-NAME-" DELIMITED BY SIZE
               LK-STATE-ID-DISPLAY DELIMITED BY SIZE
               "=" DELIMITED BY SIZE
               WS-STATE-PROPERTY-NAME(LK-STATE-ID) DELIMITED BY SIZE
               INTO OUTPUT-LINE
        END-STRING
        MOVE OUTPUT-LINE TO RESULT-REC
        WRITE RESULT-REC
        
        MOVE SPACES TO OUTPUT-LINE
        STRING "LK-STATE-PROPERTY-VALUE-" DELIMITED BY SIZE
               LK-STATE-ID-DISPLAY DELIMITED BY SIZE
               "=" DELIMITED BY SIZE
               WS-STATE-PROPERTY-VALUE(LK-STATE-ID) DELIMITED BY SIZE
               INTO OUTPUT-LINE
        END-STRING
        MOVE OUTPUT-LINE TO RESULT-REC
        WRITE RESULT-REC
    END-PERFORM
    
    CLOSE RESULT-FILE
    GOBACK.
    
INITIALIZE-BLOCKS.
    *> Initialize test data with a block that has multiple properties
    MOVE 1 TO BLOCK-COUNT
    MOVE "test-block" TO BLOCK-ENTRY-NAME(1)
    MOVE 100 TO BLOCK-ENTRY-MINIMUM-STATE-ID(1)
    MOVE 107 TO BLOCK-ENTRY-MAXIMUM-STATE-ID(1)
    MOVE 2 TO BLOCK-ENTRY-PROPERTY-COUNT(1)
    
    *> First property with 2 values
    MOVE "facing" TO BLOCK-ENTRY-PROPERTY-NAME(1, 1)
    MOVE 2 TO BLOCK-ENTRY-PROPERTY-VALUE-COUNT(1, 1)
    MOVE "north" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 1, 1)
    MOVE "south" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 1, 2)
    
    *> Second property with 4 values
    MOVE "powered" TO BLOCK-ENTRY-PROPERTY-NAME(1, 2)
    MOVE 4 TO BLOCK-ENTRY-PROPERTY-VALUE-COUNT(1, 2)
    MOVE "false" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 2, 1)
    MOVE "true" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 2, 2)
    MOVE "auto" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 2, 3)
    MOVE "manual" TO BLOCK-ENTRY-PROPERTY-VALUE(1, 2, 4).

END PROGRAM Main-Blocks-ToDescription-TC-7.

